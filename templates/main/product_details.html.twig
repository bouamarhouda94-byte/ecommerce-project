{# templates/product/details.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}
    {{ product.name }} - Our Store
{% endblock %}

{% block body %}

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">

    <div class="container">

        <a class="navbar-brand" href="{{ path('home') }}">
            Our Store
        </a>

        <div class="ms-auto d-flex align-items-center gap-3">

            {% if app.user %}

                <span class="text-white">
                    Bienvenue, {{ app.user.email }} !
                </span>

                <a href="{{ path('app_logout') }}"
                   class="btn btn-outline-danger btn-sm">

                    Déconnexion

                </a>

            {% else %}

                <a href="{{ path('app_login') }}"
                   class="btn btn-outline-light btn-sm">

                    Connexion

                </a>

                <a href="{{ path('app_register') }}"
                   class="btn btn-light btn-sm">

                    Inscription

                </a>

            {% endif %}

            <a href="{{ path('cart_show') }}"
               class="btn btn-outline-light btn-sm">

                🛒 Cart

            </a>

        </div>

    </div>

</nav>

<!-- Product Details -->
<div class="container my-5">

    <div class="row">

        <!-- Product Image -->
        <div class="col-md-6">

            <img src="{{ asset('images/item.png') }}"
                 class="img-fluid rounded shadow-sm"
                 alt="{{ product.name }}">

        </div>

        <!-- Product Info -->
        <div class="col-md-6">

            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb">

                <ol class="breadcrumb">

                    <li class="breadcrumb-item">

                        <a href="{{ path('app_browse_categories') }}"
                           class="text-decoration-none">

                            Categories

                        </a>

                    </li>

                    <li class="breadcrumb-item">

                        <a href="{{ path('app_products_by_category', {
                            id: product.category.id
                        }) }}"
                           class="text-decoration-none">

                            {{ product.category.name }}

                        </a>

                    </li>

                    <li class="breadcrumb-item active">

                        {{ product.name }}

                    </li>

                </ol>

            </nav>

            <!-- Category -->
            <span class="badge bg-primary mb-3">

                {{ product.category.name }}

            </span>

            <!-- Product Name -->
            <h1 class="mb-3">

                {{ product.name }}

            </h1>

            <!-- Price -->
            <h3 class="text-success mb-4">

                {{ product.price }} €

            </h3>

            <!-- Description -->
            <div class="mb-4">

                <h5>Description</h5>

                <p class="text-muted">

                    {{ product.description }}

                </p>

            </div>

            <!-- Extra Info -->
            <div class="mt-4 pt-4 border-top">

                <ul class="list-unstyled">

                    <li class="mb-2">

                        <strong>Availability:</strong>

                        <span class="text-success">
                            In Stock
                        </span>

                    </li>

                    <li class="mb-2">

                        <strong>Category:</strong>

                        {{ product.category.name }}

                    </li>

                </ul>

            </div>

            <!-- Buttons -->
            <div class="d-flex gap-3 mt-3">

                <form action="{{ path('cart_add', {
                    id: product.id
                }) }}"
                      method="POST">

                    <button type="submit"
                            class="btn btn-primary btn-lg">

                        🛒 Add to Cart

                    </button>

                </form>

                <a href="{{ path('app_products_by_category', {
                    id: product.category.id
                }) }}"
                   class="btn btn-outline-secondary btn-lg">

                    Continue Shopping

                </a>

            </div>

        </div>

    </div>

</div>

<!-- Footer -->
<footer class="bg-dark text-white mt-5 py-4">

    <div class="container">

        <div class="row">

            <div class="col-md-6">

                <h5>Our Store</h5>

            </div>

            <div class="col-md-6 text-md-end">

                <p>
                    &copy; 2026 Our Store.
                </p>

            </div>

        </div>

    </div>

</footer>

{% endblock %}